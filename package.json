{
  "name": "valar-digital-featured-collection",
  "version": "1.0.0",
  "description": "Shopify Featured Collection Showcase — Valar Digital take-home",
  "scripts": {
    "build": "esbuild src/featured-collection.ts --bundle --outfile=assets/featured-collection.js --platform=browser --target=es2020 --minify",
    "build:dev": "esbuild src/featured-collection.ts --bundle --outfile=assets/featured-collection.js --platform=browser --target=es2020 --sourcemap",
    "build:proxy": "tsc -p proxy/tsconfig.json",
    "dev:proxy": "node proxy/dist/proxy/src/server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0",
    "@types/node": "^20.0.0"
  },
  "dependencies": {
    "dotenv": "^16.0.0"
  }
}
