# Shopify Admin API token (keep SECRET — never commit .env)
SHOPIFY_ADMIN_API_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Shopify store domain (e.g. my-store.myshopify.com)
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com

# Port for the local App Proxy server
PORT=3000

# Shopify App Proxy shared secret (from app settings in Partners dashboard)
PROXY_SHARED_SECRET=your_proxy_shared_secret_here
